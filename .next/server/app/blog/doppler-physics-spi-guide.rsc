ildren":[["$","div",null,{"className":"flex items-start gap-4 mb-3","children":[["$","span",null,{"className":"font-mono text-2xl font-bold text-teal/30 shrink-0","children":"01"}],["$","h2",null,{"className":"font-display text-xl font-bold text-cream","children":"The Doppler Effect & Doppler Equation"}]]}],"$L12"]}],"$L13","$L14","$L15","$L16","$L17"],"$L18","$L19","$L1a"]}],"$L1b","$L1c","$L1d"]}]}],"$L1e"],null,"$L1f"]}]

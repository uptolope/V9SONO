# ═══════════════════════════════════════════════════════════════════
# SonoPrep — Environment Variables
# Copy this file to .env.local and fill in your values
# ═══════════════════════════════════════════════════════════════════

# ── Database (PostgreSQL — Supabase or Neon recommended) ──────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/sonoprep?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="GENERATE_A_RANDOM_32_CHAR_SECRET_HERE"
NEXTAUTH_URL="https://sonoprep.com"

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ── Stripe Price IDs ──────────────────────────────────────────────
STRIPE_PRICE_FLASHCARDS="price_1SOSPwItoc9MxAbzIIsmWTZ1"
STRIPE_PRICE_PHYSICS_PEARLS="price_1SOSEHItoc9MxAbzvq901JpV"
STRIPE_PRICE_EXAM_SIMULATOR="price_1SOSDPItoc9MxAbzEc3CnpdP"
STRIPE_PRICE_STUDY_NOTES="price_1SOSCQItoc9MxAbzCPRJ1IzS"
STRIPE_PRICE_PREMIUM_BUNDLE="price_1SOSRaItoc9MxAbzJhtQaa9F"

# ── Public App URL ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://sonoprep.com"

# ── Google OAuth (Optional — for Google sign-in) ─────────────────
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# ── MailerLite (Demo lead nurturing) ─────────────────────────────
MAILERLITE_API_KEY=""
MAILERLITE_GROUP_ID=""

# ── Google Sheets (Lead tracking) ────────────────────────────────
# Paste the ENTIRE JSON key file content as one line (stringify it)
GOOGLE_SERVICE_ACCOUNT_KEY=""
GOOGLE_SHEETS_SPREADSHEET_ID=""

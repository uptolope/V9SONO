# ═══════════════════════════════════════════════════════════════════
# SonoPrep — Environment Variables
# Copy this to .env.local for local dev, or set in Vercel dashboard
# ═══════════════════════════════════════════════════════════════════

# ── Database (Prisma / PostgreSQL) ────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/sonoprep?sslmode=require"

# ── NextAuth ──────────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
# In production: NEXTAUTH_URL="https://sonoprep.com"

# ── Stripe ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_..."

# Original 5-product store price IDs
STRIPE_PRICE_FLASHCARDS="price_..."
STRIPE_PRICE_EXAM_SIMULATOR="price_..."
STRIPE_PRICE_PHYSICS_PEARLS="price_..."
STRIPE_PRICE_STUDY_NOTES="price_..."
STRIPE_PRICE_PREMIUM_BUNDLE="price_..."

# Question bank product price IDs
STRIPE_PRICE_PHYSICS_QB="price_..."
STRIPE_PRICE_ABDOMEN_QB="price_..."
STRIPE_PRICE_VASCULAR_QB="price_..."

# ── MailerLite ────────────────────────────────────────────────────
MAILERLITE_API_KEY="eyJ..."
MAILERLITE_GROUP_ID="123456789"

# ── Google Sheets (optional — lead logging) ───────────────────────
# GOOGLE_SHEETS_ID="your-sheet-id"
